# Local .terraform directories
.terraform/
.terraform.lock.hcl
# .tfstate files
*.tfstate
*.tfstate.*
CLAUDE.md
terraform_vars.json

# Crash log files
crash.log
crash.*.log

*.zip
venv/
__pycache__/
# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Keep starter_pack_category.auto.tfvars tracked
!ai-accelerator-tf/starter_pack_category.auto.tfvars

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Registration artifacts generated during terraform apply/test
ai-accelerator-tf/*-postflight
ai-accelerator-tf/*-preflight
ai-accelerator-tf/*-capacity

ai-accelerator-tf/schema.yaml
ai-accelerator-tf/schemas/generated/

.DS_Store
.cursor/

# Test artifacts from /deploy-and-test (reports, recordings)
.claude/test-artifacts/

*.tfplan

terraform_vars.json


# Zipped archives from /zip-tf (track the directory via .gitkeep, ignore contents)
zipped/*
!zipped/.gitkeep

# Release test matrix artifacts
release_test_matrix/

# Excel temp/lock files
~$*

# Git worktrees
.worktrees/

# Superpowers brainstorming/planning artifacts (auto-generated, not for review)
docs/superpowers/

