      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(oci resource-manager:*)",
      "Bash(oci ce:*)",
      "Bash(oci iam:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)"
