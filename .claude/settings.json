{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(terraform init:*)",
      "Bash(terraform test:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(tflint:*)",
      "Bash(checkov:*)",
      "Bash(pytest:*)",
      "Bash(python3 create_final_schema.py:*)",
      "Bash(zip:*)",
